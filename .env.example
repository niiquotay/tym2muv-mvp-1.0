# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_REALTIME_EVENTS_PER_SECOND=50
VITE_GEMINI_API_KEY=your-gemini-key
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx

# Upstash Redis Cache Layer
VITE_UPSTASH_REDIS_REST_URL=your-upstash-redis-url
VITE_UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Cloudinary Image Optimization
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_API_KEY=your-api-key
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Datadog Observability
VITE_DATADOG_APP_ID=your-datadog-app-id
VITE_DATADOG_CLIENT_TOKEN=your-datadog-client-token
VITE_DATADOG_SITE=datadoghq.com
VITE_ENV=development
