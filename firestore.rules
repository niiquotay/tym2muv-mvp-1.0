rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin"; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role in ['Customer', 'Admin', 'Tenant'] &&
             data.id == request.auth.uid;
    }
    
    function isValidAgent(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role == 'Agent' &&
             data.id == request.auth.uid;
    }

    function isValidListing(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'sellerId', 'type', 'propertyType']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() <= 200 &&
             data.sellerId is string && data.sellerId == request.auth.uid &&
             data.type in ['Rent', 'Sale'] &&
             data.propertyType in ['Apartment', 'House', 'Condo', 'Land', 'Commercial', 'Office', 'Retail', 'Warehouse', 'Villa'];
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'participants']) &&
             data.id is string && data.id.size() <= 128 &&
             data.participants is list && data.participants.size() > 1 && data.participants.size() <= 10 &&
             request.auth.uid in data.participants;
    }

    function isValidChatMessage(data, chatPath) {
      return data.keys().hasAll(['id', 'senderId', 'text', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             request.auth.uid in get(chatPath).data.participants;
    }

    function isValidViewRequest(data) {
      return data.keys().hasAll(['id', 'listingId', 'tenantId', 'agentId', 'status', 'requestedDate', 'requestedTime', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.listingId is string && data.listingId.size() <= 128 &&
             data.tenantId is string && data.tenantId == request.auth.uid &&
             data.agentId is string && data.agentId.size() <= 128 &&
             data.status in ['pending', 'approved', 'rejected', 'completed'] &&
             data.requestedDate is string && data.requestedDate.size() <= 20 &&
             data.requestedTime is string && data.requestedTime.size() <= 20 &&
             data.createdAt is string && data.createdAt.size() <= 30;
    }

    // --- RULES ---
    
    // Users Collection (Tenants / Customers)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin(); // Only see your own profile or if Admin. Prevents PII leak.
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().role != 'Admin';
      allow update: if (isAdmin() || (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'location', 'bio', 'socials'])));
    }

    // Agents Collection (Public Profiles)
    match /agents/{agentId} {
      allow read: if true; 
      allow create: if isOwner(agentId) && isValidId(agentId) && isValidAgent(incoming());
      allow update: if (isAdmin() || (isOwner(agentId) && isValidAgent(incoming()) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'location', 'bio', 'agencyName', 'licenseNumber', 'specialization', 'socials'])));
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(listingId) && isValidListing(incoming()) && exists(/databases/$(database)/documents/agents/$(request.auth.uid));
      allow update: if (isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid && isValidListing(incoming()) && incoming().sellerId == existing().sellerId));
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow get: if isOwner(existing().userId) || isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);
      allow list: if isOwner(existing().userId) || isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);
      allow create: if isOwner(incoming().userId) && incoming().amount > 0 && incoming().status in ['pending', 'completed'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Chats Collection
    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().participants;
      allow list: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().participants == existing().participants && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'unreadCount', 'lastSenderId']);
      
      match /messages/{messageId} {
        allow get: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming(), /databases/$(database)/documents/chats/$(chatId));
        allow update, delete: if false;
      }
    }

    match /monetization/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && existing() == null && incoming().customerId == request.auth.uid && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 && incoming().vendorId is string;
      allow update, delete: if isAdmin();
    }

    match /view_requests/{requestId} {
      allow get: if isAdmin() || (isSignedIn() && (existing().tenantId == request.auth.uid || existing().agentId == request.auth.uid));
      allow list: if isAdmin() || (isSignedIn() && (existing().tenantId == request.auth.uid || existing().agentId == request.auth.uid));
      allow create: if isSignedIn() && isValidId(requestId) && isValidViewRequest(incoming()) && exists(/databases/$(database)/documents/agents/$(incoming().agentId));
      allow update: if isAdmin() || (
        isSignedIn() && 
        (
          // Tenant can only edit requestedDate, requestedTime, message if pending
          (isOwner(existing().tenantId) && existing().status == 'pending' && incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['requestedDate', 'requestedTime', 'message'])) ||
          // Agent can approve/reject/complete
          (isOwner(existing().agentId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'message']))
        ) && 
        incoming().tenantId == existing().tenantId && 
        incoming().agentId == existing().agentId && 
        incoming().listingId == existing().listingId
      );
      allow delete: if isAdmin();
    }
  }
}
