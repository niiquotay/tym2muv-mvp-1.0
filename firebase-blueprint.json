{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "location": { "type": "string" },
        "memberSince": { "type": "string" },
        "bio": { "type": "string" },
        "verified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Agent", "Customer", "Admin", "Tenant"] },
        "socials": {
          "type": "object",
          "properties": {
            "whatsapp": { "type": "string" },
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "website": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "role"]
    },
    "Agent": {
      "title": "Agent",
      "description": "Agent/Agency specific profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "location": { "type": "string" },
        "memberSince": { "type": "string" },
        "bio": { "type": "string" },
        "verified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Agent"] },
        "agencyName": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "specialization": { "type": "array", "items": { "type": "string" } },
        "socials": {
          "type": "object",
          "properties": {
            "whatsapp": { "type": "string" },
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "website": { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "role"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "refunded"] },
        "purpose": { "type": "string", "enum": ["subscription", "promotion", "listing_fee"] },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "string" },
        "gateway": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "currency", "status", "purpose", "createdAt"]
    },
    "Listing": {
      "title": "Listing",
      "description": "Property listing information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string" },
        "imageUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "videos": { "type": "array", "items": { "type": "string" } },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "datePosted": { "type": "string" },
        "expiryDate": { "type": "string" },
        "sellerId": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Rent", "Sale"] },
        "propertyType": { "type": "string" },
        "bedrooms": { "type": "integer" },
        "bathrooms": { "type": "integer" },
        "sqft": { "type": "integer" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "furnished": { "type": "boolean" },
        "parking": { "type": "boolean" },
        "security": { "type": "boolean" },
        "petsAllowed": { "type": "boolean" },
        "yearBuilt": { "type": "integer" },
        "isVerified": { "type": "boolean" },
        "virtualTourUrl": { "type": "string" }
      },
      "required": ["id", "title", "price", "location", "sellerId", "type", "propertyType"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "listingId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string" },
        "unreadCount": { "type": "integer" }
      },
      "required": ["id", "participants"]
    },
    "ViewRequest": {
      "title": "ViewRequest",
      "description": "Request from a tenant to view a listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "tenantId": { "type": "string" },
        "agentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "requestedDate": { "type": "string" },
        "requestedTime": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "listingId", "tenantId", "agentId", "status", "requestedDate", "requestedTime", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "senderId", "text", "timestamp"]
    },
    "Monetization": {
      "title": "Monetization",
      "description": "Monetization options and ads",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["banner", "popup", "card", "tall"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "cta": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "color": { "type": "string" },
        "active": { "type": "boolean" },
        "countryCode": { "type": "string" },
        "priority": { "type": "integer" },
        "clicks": { "type": "integer" },
        "impressions": { "type": "integer" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "type", "title", "link", "active"]
    },
    "Review": {
      "title": "Review",
      "description": "Review and rating for a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "customerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "vendorId", "customerId", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Agent profiles"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Property listings"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat"
    },
    "/monetization/{adId}": {
      "schema": "Monetization",
      "description": "Monetization options and ads"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Vendor reviews"
    },
    "/view_requests/{requestId}": {
      "schema": "ViewRequest",
      "description": "Property view requests from tenants to agents"
    }
  }
}
