rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ====== GLOBAL PRIMITIVES ======
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin"; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role in ['Agent', 'Customer', 'Admin', 'Tenant'] &&
             data.id == request.auth.uid;
    }
    
    function isValidAgent(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role == 'Agent' &&
             data.id == request.auth.uid;
    }

    function isValidListing(data) {
      return data.keys().hasAll(['id', 'title', 'price', 'location', 'sellerId', 'type', 'propertyType']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.location is string && data.location.size() <= 200 &&
             data.sellerId is string && data.sellerId == request.auth.uid &&
             data.type in ['Rent', 'Sale'];
    }

    // Validation for Chat
    function isValidChat(data) {
      return data.keys().hasAll(['id', 'participants']) &&
             data.id is string && data.id.size() <= 128 &&
             data.participants is list && data.participants.size() > 1 && data.participants.size() <= 10 &&
             request.auth.uid in data.participants;
    }

    function isValidChatMessage(data, chatPath) {
      return data.keys().hasAll(['id', 'senderId', 'text', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             request.auth.uid in get(chatPath).data.participants;
    }

    // Validation for Payment (Admins or System only, but if we need a strict schema)
    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'userId', 'amount', 'currency', 'status', 'purpose', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'completed', 'failed', 'refunded'] &&
             data.purpose in ['subscription', 'promotion', 'listing_fee'];
    }

    // ====== PATH RULES ======
    
    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Basic read for listing display, could be locked down
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().role != 'Admin';
      allow update: if (isAdmin() || (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'location', 'bio', 'socials'])));
    }

    // Agents Collection
    match /agents/{agentId} {
      allow read: if true; // Public agent directories
      allow create: if isOwner(agentId) && isValidId(agentId) && isValidAgent(incoming());
      allow update: if (isAdmin() || (isOwner(agentId) && isValidAgent(incoming()) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'location', 'bio', 'agencyName', 'licenseNumber', 'specialization', 'socials'])));
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true; // Public
      allow create: if isSignedIn() && isValidId(listingId) && isValidListing(incoming()) && exists(/databases/$(database)/documents/agents/$(request.auth.uid));
      allow update: if (isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid && isValidListing(incoming()) && incoming().sellerId == existing().sellerId));
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isOwner(existing().userId) || isAdmin();
      // Clients should NOT be able to create fully trusted payments. They MUST be created via Cloud Function or strictly controlled.
      // Assuming cloud function creates and updates payments. 
      allow create, update, delete: if false; 
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().participants == existing().participants && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'unreadCount', 'lastSenderId']);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming(), /databases/$(database)/documents/chats/$(chatId));
        // No updates or deletes on messages for compliance
        allow update, delete: if false;
      }
    }

    // Monetization (Ads)
    match /monetization/{adId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && existing() == null && incoming().customerId == request.auth.uid && incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 && incoming().vendorId is string;
      allow update, delete: if isAdmin();
    }
  }
}
