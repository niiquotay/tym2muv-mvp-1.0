{
  "title": "Tym2Muv Executive Dashboard",
  "description": "Production observability for web, API, and DB performance.",
  "widgets": [
    {
      "definition": {
         "type": "timeseries",
         "requests": [
            {
               "q": "sum:tym2muv.web.request_count{env:production}.as_count()",
               "display_type": "line"
            }
         ],
         "title": "API Request Volume"
      }
    },
    {
       "definition": {
          "type": "timeseries",
          "requests": [
             {
                "q": "avg:tym2muv.web.request_latency{env:production} by {endpoint}",
                "display_type": "line"
             }
          ],
          "title": "Latency by Endpoint (ms)"
       }
    },
    {
       "definition": {
          "type": "query_value",
          "requests": [
             {
                "q": "sum:tym2muv.web.error_count{env:production}.as_rate() / sum:tym2muv.web.request_count{env:production}.as_rate() * 100",
                "aggregator": "avg"
             }
          ],
          "title": "Global Error Rate (%)"
       }
    },
    {
       "definition": {
          "type": "timeseries",
          "requests": [
             {
                "q": "sum:tym2muv.business.payment_processed{status:failure}.as_count()",
                "display_type": "bars"
             }
          ],
          "title": "Payment Failures"
       }
    },
    {
      "definition": {
         "type": "timeseries",
         "requests": [
            {
               "q": "sum:tym2muv.business.listing_created{*}.as_count()",
               "display_type": "bars"
            }
         ],
         "title": "Listings Created (Hourly)"
      }
    }
  ],
  "layout_type": "ordered"
}
